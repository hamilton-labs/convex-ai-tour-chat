{
  "image": "mcr.microsoft.com/devcontainers/javascript-node:24",
  "workspaceMount":
    "source=${localWorkspaceFolder}/,target=/workspace/,type=bind,consistency=cached",
  "appPort": [ "3001:3000" ],
  "postCreateCommand": [ "git config --global user.name \"hamilton-labs\"" ],
  "postCreateCommand": [ "git config --global user.email \"173300401+hamilton-labs@users.noreply.github.com\"" ]
}
